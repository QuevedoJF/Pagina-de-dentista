---
import Layout from '../layouts/Layout.astro';
import { queries } from '../lib/db';

const siteConfig = await queries.siteConfig.getAll();
const config: Record<string, string> = {};
siteConfig.forEach((item: any) => { config[item.clave] = item.valor; });
---

<Layout title="Contacto">
  <section class="py-20 bg-gray-50">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h1 class="section-title">Contáctanos</h1>
        <p class="section-subtitle mx-auto">Estamos aquí para atenderte</p>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <div class="bg-white p-8 rounded-2xl shadow-lg">
          <h2 class="text-2xl font-display font-semibold mb-6">{config['ubicacion_titulo'] || 'Nuestra Ubicación'}</h2>
          <div class="space-y-4 text-gray-600">
            <p class="flex items-center gap-3">
              <svg class="w-6 h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              {config['ubicacion_direccion'] || 'Av. Libertadores 1234, San Isidro, Lima'}
            </p>
            <p class="flex items-center gap-3">
              <svg class="w-6 h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              {config['ubicacion_telefono'] || '+51 987 654 321'}
            </p>
            <p class="flex items-center gap-3">
              <svg class="w-6 h-6 text-gold-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              {config['ubicacion_email'] || 'contacto@clinica-dental.lux'}
            </p>
          </div>
          {config['ubicacion_mapa'] && (
            <a href={config['ubicacion_mapa']} target="_blank" class="btn-primary mt-6 inline-block">Ver en Maps</a>
          )}
        </div>

        <div class="bg-white p-8 rounded-2xl shadow-lg">
          <h2 class="text-2xl font-display font-semibold mb-6">Envíanos un Mensaje</h2>
          <form class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Nombre</label>
              <input type="text" class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
              <input type="email" class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Mensaje</label>
              <textarea rows="4" class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500"></textarea>
            </div>
            <button type="submit" class="btn-primary w-full">Enviar Mensaje</button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>