---
import Layout from '../layouts/Layout.astro';
import { queries } from '../lib/db';
import { getSession } from '../lib/auth';
import ToothSlider from '../components/ui/ToothSlider.astro';

const session = await getSession(Astro);
const siteConfig = await queries.siteConfig.getAll();
const config: Record<string, string> = {};
siteConfig.forEach((item: any) => { config[item.clave] = item.valor; });

const carouselItems = await queries.carousel.getActive();
const reviews = await queries.reviews.getActive();
const stats = await queries.reviews.getStats();
---

<Layout title="Inicio">
  <!-- Hero Section -->
  <section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-to-br from-gray-50 via-white to-gold-50">
    <div class="absolute inset-0 overflow-hidden">
      <div class="absolute top-20 right-20 w-96 h-96 bg-gold-200 rounded-full blur-3xl opacity-60 animate-pulse"></div>
      <div class="absolute bottom-20 left-20 w-80 h-80 bg-gold-300 rounded-full blur-3xl opacity-40 animate-float"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] border border-gold-200 rounded-full opacity-20"></div>
    </div>

    <div class="relative z-10 max-w-6xl mx-auto px-6 py-20 text-center">
      <div class="animate-fade-in-up">
        <h1 class="text-5xl md:text-7xl font-display font-bold text-gray-900 mb-6 leading-tight">
          {config['hero_titulo'] || 'Sonrisa Perfecta, Vida Perfecta'}
        </h1>
        <p class="text-xl md:text-2xl text-gray-600 mb-10 max-w-3xl mx-auto leading-relaxed">
          {config['hero_subtitulo'] || 'Experimenta el cuidado dental de clase mundial'}
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/contacto" class="btn-primary text-lg px-8 py-4 shadow-xl hover:shadow-2xl hover:scale-105 transition-all duration-300">
            {config['hero_cta'] || 'Agenda tu Cita'}
          </a>
          <a href="/servicios" class="btn-secondary text-lg px-8 py-4 hover:scale-105 transition-all duration-300">
            Ver Servicios
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Carousel Section -->
  {carouselItems.length > 0 && (
    <section class="py-20 bg-gradient-to-b from-white to-gray-50">
      <div class="max-w-7xl mx-auto px-6">
        <div class="relative overflow-hidden rounded-3xl shadow-2xl group">
          <div id="carousel" class="flex transition-transform duration-700 ease-out">
            {carouselItems.map((item: any, index: number) => (
              <div class="min-w-full relative" data-index={index}>
                <img src={item.imagen_url} alt={item.titulo || 'Carousel image'} class="w-full h-[500px] md:h-[600px] object-cover transition-transform duration-700 group-hover:scale-105" />
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12">
                  {item.titulo && <h3 class="text-3xl md:text-4xl font-display font-semibold text-white mb-3 transform translate-y-0 opacity-100 transition-all duration-500">{item.titulo}</h3>}
                  {item.subtitulo && <p class="text-white/80 text-lg md:text-xl max-w-2xl">{item.subtitulo}</p>}
                </div>
              </div>
            ))}
          </div>
          <div class="absolute bottom-6 left-1/2 transform -translate-x-1/2 flex gap-3">
            {carouselItems.map((_: any, i: number) => (
              <button data-dot class={`w-3 h-3 rounded-full transition-all duration-300 ${i === 0 ? 'bg-gold-500 w-10' : 'bg-white/60 hover:bg-white'}`}></button>
            ))}
          </div>
          <button id="prevBtn" class="absolute left-4 top-1/2 -translate-y-1/2 w-14 h-14 bg-white/90 rounded-full flex items-center justify-center hover:bg-white hover:scale-110 hover:shadow-xl transition-all duration-300 opacity-0 group-hover:opacity-100">
            <svg class="w-6 h-6 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
          </button>
          <button id="nextBtn" class="absolute right-4 top-1/2 -translate-y-1/2 w-14 h-14 bg-white/90 rounded-full flex items-center justify-center hover:bg-white hover:scale-110 hover:shadow-xl transition-all duration-300 opacity-0 group-hover:opacity-100">
            <svg class="w-6 h-6 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          </button>
        </div>
      </div>
    </section>
  )}

  <!-- Tooth Slider Section -->
  <section class="py-24 bg-gradient-to-b from-white via-gold-50 to-white">
    <div class="max-w-6xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="section-title animate-fade-in-up">Transforma Tu Sonrisa</h2>
        <p class="section-subtitle mx-auto animate-fade-in-up">Observa el resultado de nuestros tratamientos profesionales</p>
      </div>
      <div class="transform hover:scale-[1.02] transition-transform duration-500">
        <ToothSlider />
      </div>
    </div>
  </section>

  <!-- About Preview -->
  <section class="py-24 bg-white relative overflow-hidden">
    <div class="absolute top-0 right-0 w-96 h-96 bg-gold-100 rounded-full blur-3xl opacity-50"></div>
    <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-center relative z-10">
      <div class="relative group">
        <img src={config['sobre_nosotros_imagen'] || 'https://images.unsplash.com/photo-1629909613654-28e377c37b09?w=600&h=400&fit=crop'} alt="Nuestra clínica" class="rounded-3xl shadow-2xl w-full transform group-hover:scale-[1.02] transition-transform duration-500" />
        <div class="absolute -bottom-6 -left-6 w-48 h-48 bg-gold-500 rounded-3xl -z-10 transform group-hover:scale-110 transition-transform duration-500"></div>
      </div>
      <div>
        <h2 class="section-title">{config['sobre_nosotros_titulo'] || 'Sobre Nosotros'}</h2>
        <div class="prose prose-lg text-gray-600 mt-6" set:html={config['sobre_nosotros_contenido'] || ''} />
        <a href="/sobre-nosotros" class="btn-secondary mt-8 inline-block hover:scale-105 transition-transform duration-300">Conoce Más</a>
      </div>
    </div>
  </section>

  <!-- Reviews Section -->
  <section class="py-24 bg-gradient-to-br from-gold-50 via-white to-gold-100">
    <div class="max-w-7xl mx-auto px-6">
      <div class="text-center mb-16">
        <h2 class="section-title">Lo Que Dicen Nuestros Pacientes</h2>
        {stats?.promedio && (
          <div class="flex items-center justify-center gap-2 mt-4">
            <div class="flex">
              {[1,2,3,4,5].map(i => (
                <svg class={`w-6 h-6 ${i <= Math.round(stats.promedio) ? 'text-gold-500' : 'text-gray-300'}`} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <span class="text-xl font-semibold text-gray-700">{Number(stats.promedio).toFixed(1)} ({stats.total} reseñas)</span>
          </div>
        )}
        {session ? (
          <a href="/reviews/new" class="inline-block mt-6 btn-primary hover:scale-105 transition-transform duration-300">
            Deja tu reseña
          </a>
        ) : (
          <a href="/login" class="inline-block mt-6 btn-secondary hover:scale-105 transition-transform duration-300">
            Inicia sesión para dejar tu reseña
          </a>
        )}
      </div>
      <div class="grid md:grid-cols-3 gap-8">
        {reviews.slice(0, 3).map((review: any, index: number) => (
          <div class="bg-white p-8 rounded-2xl shadow-xl hover-lift group cursor-pointer" style={`animation-delay: ${index * 100}ms`}>
            <div class="flex mb-4">
              {[1,2,3,4,5].map(i => (
                <svg class={`w-5 h-5 ${i <= review.estrellas ? 'text-gold-500' : 'text-gray-300'} transform group-hover:scale-125 transition-transform duration-300`} style={`transition-delay: ${i * 50}ms`} fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
              ))}
            </div>
            <p class="text-gray-600 text-lg leading-relaxed">"{review.comentario}"</p>
            <p class="mt-6 font-semibold text-gray-800 text-right">— {review.nombre_autor}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-24 bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 text-white relative overflow-hidden">
    <div class="absolute inset-0">
      <div class="absolute top-20 left-20 w-64 h-64 bg-gold-500 rounded-full blur-3xl opacity-20 animate-pulse"></div>
      <div class="absolute bottom-20 right-20 w-80 h-80 bg-gold-600 rounded-full blur-3xl opacity-30 animate-float"></div>
    </div>
    <div class="max-w-4xl mx-auto px-6 text-center relative z-10">
      <h2 class="text-4xl md:text-5xl font-display font-bold mb-6 animate-fade-in-up">¿Listo Para Tu Nueva Sonrisa?</h2>
      <p class="text-xl text-gray-300 mb-10 animate-fade-in-up">Agenda tu cita hoy y descubre la diferencia de un cuidado dental excepcional.</p>
      <a href="/contacto" class="btn-primary text-lg px-10 py-4 bg-gradient-to-r from-gold-500 to-gold-600 hover:from-gold-600 hover:to-gold-700 animate-fade-in-up hover:shadow-2xl hover:scale-105 transition-all duration-300">
        Agenda Tu Cita
      </a>
    </div>
  </section>
</Layout>

<script>
  const carousel = document.getElementById('carousel');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  const dots = document.querySelectorAll('[data-dot]');

  let currentIndex = 0;
  const totalSlides = carousel?.querySelectorAll('[data-index]').length || 0;

  function goTo(index: number) {
    if (!carousel) return;
    currentIndex = Math.max(0, Math.min(index, totalSlides - 1));
    carousel.style.transform = `translateX(-${currentIndex * 100}%)`;
    dots.forEach((dot, i) => {
      (dot as HTMLElement).className = `w-3 h-3 rounded-full transition-all ${i === currentIndex ? 'bg-gold-500 w-8' : 'bg-white/50'}`;
    });
  }

  prevBtn?.addEventListener('click', () => goTo(currentIndex - 1));
  nextBtn?.addEventListener('click', () => goTo(currentIndex + 1));
  dots.forEach((dot, i) => dot.addEventListener('click', () => goTo(i)));

  setInterval(() => goTo(currentIndex + 1), 5000);
</script>