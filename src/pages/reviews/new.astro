---
import Layout from '../../layouts/Layout.astro';
import { getSession } from '../../lib/auth';
import pool from '../../lib/db';

const session = await getSession(Astro);

if (!session) {
  return Astro.redirect('/login');
}

const existingReview = await pool.query(
  'SELECT id FROM reviews WHERE user_id = $1',
  [session.id]
);

if (existingReview.rows.length > 0) {
  return Astro.redirect('/?review=already');
}

let error = '';
let success = '';

if (Astro.request.method === 'POST') {
    const checkExisting = await pool.query(
      'SELECT id FROM reviews WHERE user_id = $1',
      [session.id]
    );
    if (checkExisting.rows.length > 0) {
      return Astro.redirect('/?review=already');
    }

    const formData = await Astro.request.formData();
    const comentario = formData.get('comentario') as string;
    const estrellas = parseInt(formData.get('estrellas') as string) || 5;

    if (!comentario || comentario.trim().length < 10) {
      error = 'Por favor escribe una reseña de al menos 10 caracteres';
    } else if (estrellas < 1 || estrellas > 5) {
      error = 'Las estrellas deben estar entre 1 y 5';
    } else {
      try {
        await pool.query(
          'INSERT INTO reviews (user_id, nombre_autor, comentario, estrellas, activo) VALUES ($1, $2, $3, $4, false)',
          [session.id, session.nombre, comentario, estrellas]
        );
        return Astro.redirect('/?review=success');
      } catch (err: any) {
        error = 'Error al enviar tu reseña. Intenta de nuevo.';
      }
    }
  }
---

<Layout title="Deja tu Reseña">
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-50 via-white to-gold-50 py-12">
    <div class="w-full max-w-lg">
      <div class="bg-white rounded-2xl shadow-2xl p-8">
        <div class="text-center mb-8">
          <div class="w-16 h-16 bg-gradient-to-br from-gold-500 to-gold-700 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
          </div>
          <h1 class="text-2xl font-display font-bold text-gray-900">Deja tu Reseña</h1>
          <p class="text-gray-500 mt-2">Cuéntanos tu experiencia con nosotros</p>
        </div>

        {error && (
          <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
            {error}
          </div>
        )}

        {success && (
          <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700 text-sm">
            {success}
          </div>
        )}

        <form method="POST" class="space-y-6">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-3">¿Cómo calificarías tu experiencia?</label>
            <div class="flex gap-2 justify-center">
              {[1, 2, 3, 4, 5].map((star) => (
                <button type="button" data-star={star} class="star-btn text-4xl text-gray-300 hover:text-gold-500 transition-colors duration-200">
                  ★
                </button>
              ))}
            </div>
            <input type="hidden" name="estrellas" id="estrellas" value="5" />
          </div>

          <div>
            <label for="comentario" class="block text-sm font-medium text-gray-700 mb-2">Tu reseña</label>
            <textarea
              id="comentario"
              name="comentario"
              rows="5"
              required
              minlength="10"
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gold-500 focus:border-gold-500 transition-colors resize-none"
              placeholder="Cuéntanos en detalle tu experiencia con nuestra clínica..."
            ></textarea>
          </div>

          <button type="submit" class="w-full btn-primary py-4 text-lg">
            Enviar Reseña
          </button>
        </form>

        <p class="mt-6 text-center text-gray-500 text-sm">
          <a href="/" class="text-gold-600 hover:text-gold-700 font-medium">Volver al inicio</a>
        </p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const starBtns = document.querySelectorAll('.star-btn');
  const estrellasInput = document.getElementById('estrellas') as HTMLInputElement;

  starBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      const star = parseInt(btn.getAttribute('data-star') || '5');
      estrellasInput.value = star.toString();
      starBtns.forEach((b, i) => {
        (b as HTMLElement).style.color = i < star ? '#d4af55' : '#d1d5db';
      });
    });
  });

  starBtns.forEach((b, i) => {
    (b as HTMLElement).style.color = i < 5 ? '#d4af55' : '#d1d5db';
  });
</script>