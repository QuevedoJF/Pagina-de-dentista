---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Sobre Nosotros">
  <section class="py-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid md:grid-cols-2 gap-16 items-center mb-20">
        <div>
          <h1 class="section-title">{Astro.locals.config?.['sobre_nosotros_titulo'] || 'Sobre Nosotros'}</h1>
          <div class="prose prose-lg text-gray-600 mt-6" set:html={Astro.locals.config?.['sobre_nosotros_contenido'] || ''} />
        </div>
        <div class="relative">
          <img src={Astro.locals.config?.['sobre_nosotros_imagen'] || '/images/clinica.jpg'} alt="Nuestra clínica" class="rounded-2xl shadow-2xl w-full" />
          <div class="absolute -bottom-6 -left-6 w-48 h-48 bg-gold-100 rounded-2xl -z-10"></div>
        </div>
      </div>

      <div class="grid md:grid-cols-2 gap-12">
        <div class="bg-gradient-to-br from-primary-50 to-white p-8 rounded-2xl">
          <h2 class="text-3xl font-display font-semibold text-gray-900 mb-4">{Astro.locals.config?.['mision_titulo'] || 'Nuestra Misión'}</h2>
          <div class="prose text-gray-600" set:html={Astro.locals.config?.['mision_contenido'] || ''} />
        </div>
        <div class="bg-gradient-to-br from-gold-50 to-white p-8 rounded-2xl">
          <h2 class="text-3xl font-display font-semibold text-gray-900 mb-4">{Astro.locals.config?.['vision_titulo'] || 'Nuestra Visión'}</h2>
          <div class="prose text-gray-600" set:html={Astro.locals.config?.['vision_contenido'] || ''} />
        </div>
      </div>
    </div>
  </section>
</Layout>