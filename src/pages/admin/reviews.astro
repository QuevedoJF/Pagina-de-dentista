---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession } from '../../lib/auth';
import pool from '../../lib/db';

const session = await getSession(Astro);
if (!session || session.rol !== 'admin') {
  return Astro.redirect('/login');
}

let success = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const id = parseInt(formData.get('id') as string);
  const action = formData.get('action') as string;

  if (action === 'approve') {
    await pool.query('UPDATE reviews SET activo = true WHERE id = $1', [id]);
    success = 'Reseña aprobada';
  } else if (action === 'delete') {
    await pool.query('DELETE FROM reviews WHERE id = $1', [id]);
    success = 'Reseña eliminada';
  }
}

const pendingResult = await pool.query(
  "SELECT r.*, u.nombre as usuario_nombre FROM reviews r LEFT JOIN users u ON r.user_id = u.id WHERE r.activo = false AND r.user_id IS NOT NULL ORDER BY r.fecha_creacion DESC"
);
const pendingReviews = pendingResult.rows;
---

<AdminLayout title="Reseñas - Admin">
  <div class="min-h-screen bg-gray-100">
    <nav class="bg-white shadow-sm">
      <div class="max-w-7xl mx-auto px-4 py-4 flex items-center gap-4">
        <a href="/admin" class="text-gray-600 hover:text-gray-900">← Dashboard</a>
        <h1 class="text-2xl font-display font-bold text-gray-900">Moderación de Reseñas</h1>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 py-8">
      {success && <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700">{success}</div>}

      <div class="bg-white p-6 rounded-xl shadow-md">
        <p class="text-gray-600 mb-6">Reseñas pendientes de aprobación. Las eliminadas se guardan en BD para las estrellas.</p>

        <div class="space-y-4">
          {pendingReviews.length === 0 && <p class="text-gray-500 text-center py-8">No hay reseñas pendientes.</p>}

          {pendingReviews.map((item: any) => (
            <div class="p-4 border rounded-lg">
              <div class="flex items-start justify-between">
                <div class="flex-1">
                  <div class="flex items-center gap-2 mb-2">
                    <span class="font-semibold text-gray-900">{item.nombre_autor}</span>
                    <div class="flex">
                      {[1,2,3,4,5].map(i => (
                        <svg class={`w-4 h-4 ${i <= item.estrellas ? 'text-gold-500' : 'text-gray-300'}`} fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                      ))}
                    </div>
                    <span class="text-sm text-gray-400">{new Date(item.fecha_creacion).toLocaleDateString('es-ES')}</span>
                  </div>
                  <p class="text-gray-600">{item.comentario}</p>
                </div>
                <div class="flex gap-2 ml-4">
                  <form method="POST">
                    <input type="hidden" name="action" value="approve" />
                    <input type="hidden" name="id" value={item.id} />
                    <button type="submit" class="text-green-600 hover:bg-green-50 px-3 py-2 rounded border border-green-200">Aprobar</button>
                  </form>
                  <form method="POST">
                    <input type="hidden" name="action" value="delete" />
                    <input type="hidden" name="id" value={item.id} />
                    <button type="submit" class="text-red-600 hover:bg-red-50 px-3 py-2 rounded border border-red-200">Eliminar</button>
                  </form>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </main>
  </div>
</AdminLayout>