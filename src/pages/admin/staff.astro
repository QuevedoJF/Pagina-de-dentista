---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession } from '../../lib/auth';
import { queries } from '../../lib/db';

const session = await getSession(Astro);
if (!session || session.rol !== 'admin') {
  return Astro.redirect('/login');
}

let success = '';

const items = await queries.staff.getAll();

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action') as string;

  if (action === 'create') {
    await queries.staff.create(
      formData.get('nombre') as string,
      formData.get('cargo') as string,
      formData.get('foto_url') as string,
      parseInt(formData.get('orden') as string) || 0
    );
    success = 'Miembro agregado';
  } else if (action === 'delete') {
    await queries.staff.delete(parseInt(formData.get('id') as string));
    success = 'Miembro eliminado';
  }
  return Astro.redirect('/admin/staff');
}
---

<AdminLayout title="Staff - Admin">
  <div class="min-h-screen bg-gray-100">
    <nav class="bg-white shadow-sm">
      <div class="max-w-7xl mx-auto px-4 py-4 flex items-center gap-4">
        <a href="/admin" class="text-gray-600 hover:text-gray-900">← Dashboard</a>
        <h1 class="text-2xl font-display font-bold text-gray-900">Personal</h1>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 py-8">
      {success && <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700">{success}</div>}

      <div class="grid lg:grid-cols-2 gap-8">
        <div class="bg-white p-6 rounded-xl shadow-md">
          <h2 class="text-lg font-semibold mb-4">Agregar Miembro</h2>
          <form method="POST" class="space-y-4">
            <input type="hidden" name="action" value="create" />
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Nombre Completo</label>
              <input type="text" name="nombre" required class="w-full px-4 py-2 border rounded-lg" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Cargo / Especialidad</label>
              <input type="text" name="cargo" required class="w-full px-4 py-2 border rounded-lg" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">URL de Foto</label>
              <input type="url" name="foto_url" class="w-full px-4 py-2 border rounded-lg" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Orden de aparición</label>
              <input type="number" name="orden" value="0" class="w-full px-4 py-2 border rounded-lg" />
            </div>
            <button type="submit" class="btn-primary w-full">Agregar al Staff</button>
          </form>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-md">
          <h2 class="text-lg font-semibold mb-4">Equipo Actual ({items.length})</h2>
          <div class="space-y-4 max-h-[500px] overflow-y-auto">
            {items.map((item: any) => (
              <div class="flex items-center gap-4 p-4 border rounded-lg">
                <img src={item.foto_url || '/images/default-avatar.png'} class="w-16 h-16 rounded-full object-cover" alt={item.nombre} />
                <div class="flex-1">
                  <h3 class="font-medium text-gray-900">{item.nombre}</h3>
                  <p class="text-sm text-gray-500">{item.cargo}</p>
                </div>
                <form method="POST">
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="id" value={item.id} />
                  <button type="submit" class="text-red-600 hover:bg-red-50 px-3 py-1 rounded">Eliminar</button>
                </form>
              </div>
            ))}
          </div>
        </div>
      </div>
    </main>
  </div>
</AdminLayout>