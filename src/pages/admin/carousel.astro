---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession } from '../../lib/auth';
import { queries } from '../../lib/db';

const session = await getSession(Astro);
if (!session || session.rol !== 'admin') {
  return Astro.redirect('/login');
}

let success = '';

const items = await queries.carousel.getAll();

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action') as string;

  if (action === 'create') {
    await queries.carousel.create(
      formData.get('imagen_url') as string,
      formData.get('titulo') as string || '',
      formData.get('subtitulo') as string || '',
      parseInt(formData.get('orden') as string) || 0
    );
    success = 'Imagen agregada al carrusel';
  } else if (action === 'delete') {
    await queries.carousel.delete(parseInt(formData.get('id') as string));
    success = 'Imagen eliminada';
  }
  return Astro.redirect('/admin/carousel');
}
---

<AdminLayout title="Carrusel - Admin">
  <div class="min-h-screen bg-gray-100">
    <nav class="bg-white shadow-sm">
      <div class="max-w-7xl mx-auto px-4 py-4 flex justify-between items-center">
        <div class="flex items-center gap-4">
          <a href="/admin" class="text-gray-600 hover:text-gray-900">← Dashboard</a>
          <h1 class="text-2xl font-display font-bold text-gray-900">Gestionar Carrusel</h1>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 py-8">
      {success && <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700">{success}</div>}

      <div class="grid lg:grid-cols-2 gap-8">
        <div class="bg-white p-6 rounded-xl shadow-md">
          <h2 class="text-lg font-semibold mb-4">Agregar Nueva Imagen</h2>
          <form method="POST" class="space-y-4">
            <input type="hidden" name="action" value="create" />
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">URL de Imagen</label>
              <input type="url" name="imagen_url" required class="w-full px-4 py-2 border rounded-lg" placeholder="https://..." />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Título</label>
              <input type="text" name="titulo" class="w-full px-4 py-2 border rounded-lg" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Subtítulo</label>
              <input type="text" name="subtitulo" class="w-full px-4 py-2 border rounded-lg" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Orden</label>
              <input type="number" name="orden" value="0" class="w-full px-4 py-2 border rounded-lg" />
            </div>
            <button type="submit" class="btn-primary w-full">Agregar al Carrusel</button>
          </form>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-md">
          <h2 class="text-lg font-semibold mb-4">Imágenes Actuales ({items.length})</h2>
          <p class="text-sm text-gray-500 mb-4">Solo las primeras 5 imágenes visibles en el front.</p>
          <div class="space-y-4 max-h-96 overflow-y-auto">
            {items.map((item: any) => (
              <div class="flex items-center gap-4 p-3 border rounded-lg">
                <img src={item.imagen_url} alt="" class="w-20 h-12 object-cover rounded" />
                <div class="flex-1">
                  <p class="font-medium text-gray-900">{item.titulo || 'Sin título'}</p>
                  <p class="text-sm text-gray-500">Orden: {item.orden} | {item.activo ? 'Activo' : 'Inactivo'}</p>
                </div>
                <form method="POST">
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="id" value={item.id} />
                  <button type="submit" class="p-2 text-red-600 hover:bg-red-50 rounded">Eliminar</button>
                </form>
              </div>
            ))}
          </div>
        </div>
      </div>
    </main>
  </div>
</AdminLayout>