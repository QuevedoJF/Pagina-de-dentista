---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession } from '../../lib/auth';
import pool from '../../lib/db';

const session = await getSession(Astro);
if (!session || session.rol !== 'admin') {
  return Astro.redirect('/login');
}

let success = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  
  await pool.query(`INSERT INTO site_config (clave, valor, tipo, categoria) 
    VALUES 
      ('cta_titulo', $1, 'text', 'cta'),
      ('cta_subtitulo', $2, 'text', 'cta')
    ON CONFLICT (clave) DO UPDATE SET valor = EXCLUDED.valor`,
    [
      formData.get('cta_titulo') as string || '',
      formData.get('cta_subtitulo') as string || ''
    ]
  );
  success = 'Cambios guardados correctamente';
}

const config: Record<string, string> = {};
const result = await pool.query('SELECT clave, valor FROM site_config WHERE categoria = $1', ['cta']);
result.rows.forEach(row => { config[row.clave] = row.valor || ''; });
---

<AdminLayout title="Llamado a la Acción - Admin">
  <div class="max-w-4xl">
    <div class="mb-8">
      <a href="/admin" class="text-gold-600 hover:text-gold-700 text-sm mb-2 inline-block">← Volver al Dashboard</a>
      <h1 class="text-3xl font-bold text-gray-900">Sección Llamado a la Acción (CTA)</h1>
      <p class="text-gray-600 mt-1">Edita el contenido de la sección de llamada a la acción</p>
    </div>

    {success && (
      <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        {success}
      </div>
    )}

    <form method="POST" class="space-y-6">
      <div class="bg-white rounded-xl shadow-md p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Contenido del CTA</h2>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Título</label>
            <input type="text" name="cta_titulo" value={config['cta_titulo'] || ''} class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" placeholder="¿Listo Para Tu Nueva Sonrisa?" />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Subtítulo</label>
            <input type="text" name="cta_subtitulo" value={config['cta_subtitulo'] || ''} class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" placeholder="Agenda tu cita hoy y descubre la diferencia..." />
          </div>
        </div>
      </div>

      <button type="submit" class="w-full btn-primary py-4 text-lg">
        Guardar Cambios
      </button>
    </form>
  </div>
</AdminLayout>