---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession } from '../../lib/auth';
import pool from '../../lib/db';

const session = await getSession(Astro);
if (!session || session.rol !== 'admin') {
  return Astro.redirect('/login');
}

let success = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  
  await pool.query(`INSERT INTO site_config (clave, valor, tipo, categoria) 
    VALUES 
      ('footer_descripcion', $1, 'text', 'footer'),
      ('footer_telefono', $2, 'text', 'footer'),
      ('footer_email', $3, 'text', 'footer'),
      ('footer_direccion', $4, 'text', 'footer'),
      ('footer_facebook', $5, 'text', 'footer'),
      ('footer_instagram', $6, 'text', 'footer')
    ON CONFLICT (clave) DO UPDATE SET valor = EXCLUDED.valor`,
    [
      formData.get('footer_descripcion') as string || '',
      formData.get('footer_telefono') as string || '',
      formData.get('footer_email') as string || '',
      formData.get('footer_direccion') as string || '',
      formData.get('footer_facebook') as string || '',
      formData.get('footer_instagram') as string || ''
    ]
  );
  success = 'Cambios guardados correctamente';
}

const config: Record<string, string> = {};
const result = await pool.query('SELECT clave, valor FROM site_config WHERE categoria = $1', ['footer']);
result.rows.forEach(row => { config[row.clave] = row.valor || ''; });
---

<AdminLayout title="Footer - Admin">
  <div class="max-w-4xl">
    <div class="mb-8">
      <a href="/admin" class="text-gold-600 hover:text-gold-700 text-sm mb-2 inline-block">← Volver al Dashboard</a>
      <h1 class="text-3xl font-bold text-gray-900">Sección Footer (Pie de Página)</h1>
      <p class="text-gray-600 mt-1">Edita el contenido del pie de página del sitio</p>
    </div>

    {success && (
      <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        {success}
      </div>
    )}

    <form method="POST" class="space-y-6">
      <div class="bg-white rounded-xl shadow-md p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Descripción</h2>
        <textarea name="footer_descripcion" rows="3" class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" placeholder="Breve descripción de la clínica">{config['footer_descripcion'] || ''}</textarea>
      </div>

      <div class="bg-white rounded-xl shadow-md p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Información de Contacto</h2>
        
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Dirección</label>
            <input type="text" name="footer_direccion" value={config['footer_direccion'] || ''} class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" placeholder="Av. Libertadores 1234, San Isidro" />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Teléfono</label>
            <input type="text" name="footer_telefono" value={config['footer_telefono'] || ''} class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" placeholder="+51 987 654 321" />
          </div>
          
          <div class="md:col-span-2">
            <label class="block text-sm font-medium text-gray-700 mb-1">Correo Electrónico</label>
            <input type="email" name="footer_email" value={config['footer_email'] || ''} class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" placeholder="contacto@clinica-dental.lux" />
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-md p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Redes Sociales</h2>
        
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Facebook</label>
            <input type="url" name="footer_facebook" value={config['footer_facebook'] || ''} class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" placeholder="https://facebook.com/clinica" />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Instagram</label>
            <input type="url" name="footer_instagram" value={config['footer_instagram'] || ''} class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" placeholder="https://instagram.com/clinica" />
          </div>
        </div>
      </div>

      <button type="submit" class="w-full btn-primary py-4 text-lg">
        Guardar Cambios
      </button>
    </form>
  </div>
</AdminLayout>