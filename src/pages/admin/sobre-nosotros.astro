---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession } from '../../lib/auth';
import pool from '../../lib/db';

const session = await getSession(Astro);
if (!session || session.rol !== 'admin') {
  return Astro.redirect('/login');
}

let success = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  
await pool.query(`INSERT INTO site_config (clave, valor, tipo, categoria) 
      VALUES 
        ('sobre_nosotros_titulo', $1, 'text', 'sobre_nosotros'),
        ('sobre_nosotros_contenido', $2, 'html', 'sobre_nosotros'),
        ('sobre_nosotros_imagen', $3, 'image', 'sobre_nosotros'),
        ('mision_titulo', $4, 'text', 'sobre_nosotros'),
        ('mision_contenido', $5, 'html', 'sobre_nosotros'),
        ('vision_titulo', $6, 'text', 'sobre_nosotros'),
        ('vision_contenido', $7, 'html', 'sobre_nosotros')
      ON CONFLICT (clave) DO UPDATE SET valor = EXCLUDED.valor`,
      [
        formData.get('sobre_titulo') as string || '',
        formData.get('sobre_contenido') as string || '',
        formData.get('sobre_imagen') as string || '',
        formData.get('mision_titulo') as string || '',
        formData.get('mision_contenido') as string || '',
        formData.get('vision_titulo') as string || '',
        formData.get('vision_contenido') as string || ''
      ]
    );
  success = 'Cambios guardados correctamente';
}

const config: Record<string, string> = {};
const result = await pool.query('SELECT clave, valor FROM site_config WHERE categoria = $1', ['sobre_nosotros']);
result.rows.forEach(row => { config[row.clave] = row.valor || ''; });
---

<AdminLayout title="Sobre Nosotros - Admin">
  <div class="max-w-4xl">
    <div class="mb-8">
      <a href="/admin" class="text-gold-600 hover:text-gold-700 text-sm mb-2 inline-block">← Volver al Dashboard</a>
      <h1 class="text-3xl font-bold text-gray-900">Sección Sobre Nosotros</h1>
      <p class="text-gray-600 mt-1">Edita el contenido de la sección "Sobre Nosotros" de la página principal</p>
    </div>

    {success && (
      <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700 flex items-center gap-2">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
        {success}
      </div>
    )}

    <form method="POST" class="space-y-6">
      <div class="bg-white rounded-xl shadow-md p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Contenido Principal</h2>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Título</label>
            <input type="text" name="sobre_titulo" value={config['sobre_nosotros_titulo'] || ''} class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" placeholder="Sobre Nosotros" />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Contenido (HTML permitido)</label>
            <textarea name="sobre_contenido" rows="5" class="w-full px-4 py-3 border rounded-lg font-mono text-sm focus:ring-2 focus:ring-gold-500">{config['sobre_nosotros_contenido'] || ''}</textarea>
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">URL de Imagen</label>
            <input type="text" name="sobre_imagen" value={config['sobre_nosotros_imagen'] || ''} class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" placeholder="https://..." />
            {config['sobre_nosotros_imagen'] && (
              <img src={config['sobre_nosotros_imagen']} alt="Preview" class="mt-2 w-64 h-40 object-cover rounded-lg" />
            )}
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-md p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Nuestra Misión</h2>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Título</label>
            <input type="text" name="mision_titulo" value={config['mision_titulo'] || ''} class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" placeholder="Nuestra Misión" />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Contenido (HTML permitido)</label>
            <textarea name="mision_contenido" rows="4" class="w-full px-4 py-3 border rounded-lg font-mono text-sm focus:ring-2 focus:ring-gold-500">{config['mision_contenido'] || ''}</textarea>
          </div>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-md p-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4">Nuestra Visión</h2>
        
        <div class="space-y-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Título</label>
            <input type="text" name="vision_titulo" value={config['vision_titulo'] || ''} class="w-full px-4 py-3 border rounded-lg focus:ring-2 focus:ring-gold-500" placeholder="Nuestra Visión" />
          </div>
          
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Contenido (HTML permitido)</label>
            <textarea name="vision_contenido" rows="4" class="w-full px-4 py-3 border rounded-lg font-mono text-sm focus:ring-2 focus:ring-gold-500">{config['vision_contenido'] || ''}</textarea>
          </div>
        </div>
      </div>

      <button type="submit" class="w-full btn-primary py-4 text-lg">
        Guardar Cambios
      </button>
    </form>
  </div>
</AdminLayout>