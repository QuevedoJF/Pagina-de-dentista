---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession } from '../../lib/auth';
import { queries } from '../../lib/db';

const session = await getSession(Astro);
if (!session || session.rol !== 'admin') {
  return Astro.redirect('/login');
}

let success = '';

const posts = await queries.blogPromos.getAll();

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const action = formData.get('action') as string;

  if (action === 'create') {
    await queries.blogPromos.create(
      formData.get('tipo') as string,
      formData.get('titulo') as string,
      formData.get('contenido') as string,
      formData.get('imagen_url') as string,
      1
    );
    success = 'Entrada creada';
  } else if (action === 'delete') {
    await queries.blogPromos.delete(parseInt(formData.get('id') as string));
    success = 'Entrada eliminada';
  }
  return Astro.redirect('/admin/blog');
}
---

<AdminLayout title="Blog y Promociones - Admin">
  <div class="min-h-screen bg-gray-100">
    <nav class="bg-white shadow-sm">
      <div class="max-w-7xl mx-auto px-4 py-4 flex items-center gap-4">
        <a href="/admin" class="text-gray-600 hover:text-gray-900">← Dashboard</a>
        <h1 class="text-2xl font-display font-bold text-gray-900">Blog y Promociones</h1>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 py-8">
      {success && <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700">{success}</div>}

      <div class="grid lg:grid-cols-2 gap-8">
        <div class="bg-white p-6 rounded-xl shadow-md">
          <h2 class="text-lg font-semibold mb-4">Crear Nueva Entrada</h2>
          <form method="POST" class="space-y-4">
            <input type="hidden" name="action" value="create" />
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tipo</label>
              <select name="tipo" class="w-full px-4 py-2 border rounded-lg">
                <option value="post">Post de Blog</option>
                <option value="promocion">Promoción</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Título</label>
              <input type="text" name="titulo" required class="w-full px-4 py-2 border rounded-lg" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Contenido (HTML permitido)</label>
              <textarea name="contenido" rows="5" class="w-full px-4 py-2 border rounded-lg"></textarea>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">URL de Imagen</label>
              <input type="url" name="imagen_url" class="w-full px-4 py-2 border rounded-lg" />
            </div>
            <button type="submit" class="btn-primary w-full">Crear Entrada</button>
          </form>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-md">
          <h2 class="text-lg font-semibold mb-4">Entradas Existentes ({posts.length})</h2>
          <div class="space-y-4 max-h-[500px] overflow-y-auto">
            {posts.map((item: any) => (
              <div class="p-4 border rounded-lg">
                <div class="flex items-center gap-2 mb-2">
                  <span class={`text-xs px-2 py-1 rounded ${item.tipo === 'promocion' ? 'bg-gold-100 text-gold-700' : 'bg-blue-100 text-blue-700'}`}>
                    {item.tipo}
                  </span>
                  {!item.visible && <span class="text-xs bg-gray-200 text-gray-600 px-2 py-1 rounded">Oculto</span>}
                </div>
                <h3 class="font-medium text-gray-900">{item.titulo}</h3>
                <p class="text-sm text-gray-500">{new Date(item.fecha_publicacion).toLocaleDateString('es-ES')}</p>
                <form method="POST" class="mt-3">
                  <input type="hidden" name="action" value="delete" />
                  <input type="hidden" name="id" value={item.id} />
                  <button type="submit" class="text-red-600 hover:bg-red-50 px-3 py-1 rounded border border-red-200 text-sm">Eliminar</button>
                </form>
              </div>
            ))}
          </div>
        </div>
      </div>
    </main>
  </div>
</AdminLayout>