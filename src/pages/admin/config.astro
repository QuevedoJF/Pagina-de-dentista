---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getSession } from '../../lib/auth';
import { queries } from '../../lib/db';

const session = await getSession(Astro);
if (!session || session.rol !== 'admin') {
  return Astro.redirect('/login');
}

let success = '';
const configItems = await queries.siteConfig.getAll();

const groupedConfig: Record<string, any[]> = {};
configItems.forEach((item: any) => {
  if (!groupedConfig[item.categoria]) groupedConfig[item.categoria] = [];
  groupedConfig[item.categoria].push(item);
});

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  await queries.siteConfig.upsert(
    formData.get('clave') as string,
    formData.get('valor') as string,
    formData.get('tipo') as string,
    formData.get('categoria') as string
  );
  success = 'Configuración actualizada';
}
---

<AdminLayout title="Configuración del Sitio">
  <div class="min-h-screen bg-gray-100">
    <nav class="bg-white shadow-sm">
      <div class="max-w-7xl mx-auto px-4 py-4 flex items-center gap-4">
        <a href="/admin" class="text-gray-600 hover:text-gray-900">← Dashboard</a>
        <h1 class="text-2xl font-display font-bold text-gray-900">Configuración del Sitio</h1>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto px-4 py-8">
      {success && <div class="mb-6 p-4 bg-green-50 border border-green-200 rounded-lg text-green-700">{success}</div>}

      <div class="space-y-8">
        {Object.entries(groupedConfig).map(([categoria, items]) => (
          <div class="bg-white p-6 rounded-xl shadow-md">
            <h2 class="text-lg font-semibold mb-4 capitalize">{categoria.replace('_', ' ')}</h2>
            <div class="space-y-4">
              {items.map((item: any) => (
                <form method="POST" class="flex gap-4 items-start">
                  <div class="flex-1">
                    <label class="block text-sm font-medium text-gray-500 mb-1">{item.clave}</label>
                    {item.tipo === 'html' ? (
                      <textarea name="valor" rows="3" class="w-full px-4 py-2 border rounded-lg font-mono text-sm">{item.valor}</textarea>
                    ) : item.tipo === 'image' ? (
                      <div class="space-y-2">
                        <input type="text" name="valor" value={item.valor} class="w-full px-4 py-2 border rounded-lg" />
                        {item.valor && <img src={item.valor} class="w-32 h-20 object-cover rounded" alt="" />}
                      </div>
                    ) : (
                      <input type="text" name="valor" value={item.valor} class="w-full px-4 py-2 border rounded-lg" />
                    )}
                  </div>
                  <input type="hidden" name="clave" value={item.clave} />
                  <input type="hidden" name="tipo" value={item.tipo} />
                  <input type="hidden" name="categoria" value={item.categoria} />
                  <button type="submit" class="mt-6 px-4 py-2 bg-gold-600 text-white rounded-lg hover:bg-gold-700 text-sm">Guardar</button>
                </form>
              ))}
            </div>
          </div>
        ))}
      </div>
    </main>
  </div>
</AdminLayout>