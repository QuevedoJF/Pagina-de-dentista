---
import Layout from '../layouts/Layout.astro';
import pool from '../lib/db';
import { getSession, createSessionCookie, verifyPassword, needsRehash, hashPassword } from '../lib/auth';

const existingSession = await getSession(Astro);
if (existingSession) {
  return Astro.redirect(existingSession.rol === 'admin' ? '/admin' : '/');
}

let error = '';

if (Astro.request.method === 'POST') {
  const formData = await Astro.request.formData();
  const nombre = formData.get('nombre') as string;
  const password = formData.get('password') as string;

  const result = await pool.query('SELECT * FROM users WHERE nombre = $1', [nombre]);
  const user = result.rows[0];

  if (user && await verifyPassword(password, user.password)) {
    if (needsRehash(user.password)) {
      const newHash = await hashPassword(password);
      await pool.query('UPDATE users SET password = $1 WHERE id = $2', [newHash, user.id]);
    }
    const sessionValue = createSessionCookie({ id: user.id, nombre: user.nombre, email: user.email, rol: user.rol });
    Astro.cookies.set('session', sessionValue, { path: '/', httpOnly: true, maxAge: 60 * 60 * 24 });
    return Astro.redirect(user.rol === 'admin' ? '/admin' : '/');
  } else {
    error = 'Credenciales inválidas';
  }
}
---

<Layout title="Iniciar Sesión">
  <div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-50 via-white to-gold-50 py-12">
    <div class="w-full max-w-md">
      <div class="bg-white rounded-2xl shadow-2xl p-8">
        <div class="text-center mb-8">
          <div class="w-16 h-16 bg-gradient-to-br from-gold-500 to-gold-700 rounded-full flex items-center justify-center mx-auto mb-4 shadow-lg">
            <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
          </div>
          <h1 class="text-2xl font-display font-bold text-gray-900">Iniciar Sesión</h1>
          <p class="text-gray-500 mt-2">Accede a tu cuenta</p>
        </div>

        {error && (
          <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
            {error}
          </div>
        )}

        <form method="POST" class="space-y-5">
          <div>
            <label for="nombre" class="block text-sm font-medium text-gray-700 mb-2">Usuario</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gold-500 focus:border-gold-500 transition-colors"
              placeholder="Tu nombre de usuario"
            />
          </div>

          <div>
            <label for="password" class="block text-sm font-medium text-gray-700 mb-2">Contraseña</label>
            <input
              type="password"
              id="password"
              name="password"
              required
              class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-gold-500 focus:border-gold-500 transition-colors"
              placeholder="Tu contraseña"
            />
          </div>

          <button type="submit" class="w-full btn-primary py-4 text-lg">
            Iniciar Sesión
          </button>
        </form>

        <p class="mt-6 text-center text-gray-500 text-sm">
          ¿No tienes cuenta? <a href="/register" class="text-gold-600 hover:text-gold-700 font-medium">Regístrate aquí</a>
        </p>
      </div>
    </div>
  </div>
</Layout>