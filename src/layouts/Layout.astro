---
import { getSession } from "../lib/auth";
import { queries } from "../lib/db";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "Clínica Dental de Lujo - Sonrisa Perfecta, Vida Perfecta",
} = Astro.props;
const session = await getSession(Astro);

const siteConfig = await queries.siteConfig.getAll();
const config: Record<string, string> = {};
siteConfig.forEach((item) => { config[item.clave] = item.valor || ''; });

Astro.locals.config = config;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} | Clínica Dental de Lujo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="font-sans bg-white text-gray-900 antialiased">
    <nav
      class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-md shadow-sm"
    >
      <div class="max-w-7xl mx-auto px-6 py-4">
        <div class="flex items-center justify-between">
          <a href="/" class="flex items-center gap-3 group">
            <div
              class="w-10 h-10 bg-gradient-to-br from-gold-500 to-gold-700 rounded-xl flex items-center justify-center shadow-lg group-hover:shadow-xl transition-all duration-300 group-hover:scale-105"
            >
              <svg
                class="w-6 h-6 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                ></path>
              </svg>
            </div>
            <span
              class="text-xl font-display font-bold text-gray-900 hidden sm:block"
              >Clinica<span class="text-gold-600">Dental</span></span
            >
          </a>

          <div class="hidden md:flex items-center gap-8">
            <a
              href="/"
              class="text-gray-600 hover:text-gold-600 font-medium transition-colors duration-200"
              >Inicio</a
            >
            <a
              href="/servicios"
              class="text-gray-600 hover:text-gold-600 font-medium transition-colors duration-200"
              >Servicios</a
            >
            <a
              href="/equipo"
              class="text-gray-600 hover:text-gold-600 font-medium transition-colors duration-200"
              >Equipo</a
            >
            <a
              href="/blog"
              class="text-gray-600 hover:text-gold-600 font-medium transition-colors duration-200"
              >Blog</a
            >
            <a
              href="/promociones"
              class="text-gray-600 hover:text-gold-600 font-medium transition-colors duration-200"
              >Promociones</a
            >
            <a
              href="/sobre-nosotros"
              class="text-gray-600 hover:text-gold-600 font-medium transition-colors duration-200"
              >Nosotros</a
            >
            <a
              href="/faq"
              class="text-gray-600 hover:text-gold-600 font-medium transition-colors duration-200"
              >FAQ</a
            >
          </div>

          <div class="flex items-center gap-4">
            {
              session ? (
                <>
                  <span class="text-gray-600 font-medium">
                    Hola, {session.nombre}
                  </span>
                  <a
                    href="/logout"
                    class="px-4 py-2 text-gray-600 hover:text-red-600 font-medium transition-colors"
                  >
                    Cerrar Sesión
                  </a>
                  {session.rol === "admin" && (
                    <a
                      href="/admin"
                      class="px-4 py-2 bg-gold-600 text-white rounded-lg hover:bg-gold-700 transition-all hover:shadow-lg text-sm font-medium"
                    >
                      Panel Admin
                    </a>
                  )}
                </>
              ) : (
                <>
                  <a
                    href="/login"
                    class="px-4 py-2 text-gray-600 hover:text-gold-600 font-medium transition-colors"
                  >
                    Iniciar Sesión
                  </a>
                  <a
                    href="/register"
                    class="px-4 py-2 bg-gold-600 text-white rounded-lg hover:bg-gold-700 transition-all hover:shadow-lg text-sm font-medium"
                  >
                    Registrarse
                  </a>
                </>
              )
            }
          </div>
        </div>
      </div>
    </nav>

    <main class="pt-20">
      <slot />
    </main>

    <footer class="bg-gray-900 text-white py-16">
      <div class="max-w-7xl mx-auto px-6">
        <div class="grid md:grid-cols-4 gap-12 mb-12">
          <div>
            <div class="flex items-center gap-3 mb-6">
              <div
                class="w-10 h-10 bg-gradient-to-br from-gold-500 to-gold-700 rounded-xl flex items-center justify-center"
              >
                <svg
                  class="w-6 h-6 text-white"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                  ></path>
                </svg>
              </div>
              <span class="text-xl font-display font-bold"
                >Clinica<span class="text-gold-500">Dental</span></span
              >
            </div>
            <p class="text-gray-400 leading-relaxed">
              {config['footer_descripcion'] || 'Clinica Dental de Lujo. Más de 15 años brinda sonrisas perfectas a nuestros pacientes.'}
            </p>
          </div>

          <div>
            <h4 class="text-lg font-semibold mb-6">Servicios</h4>
            <ul class="space-y-3 text-gray-400">
              <li>
                <a
                  href="/servicios"
                  class="hover:text-gold-500 transition-colors"
                  >Limpieza Dental</a
                >
              </li>
              <li>
                <a
                  href="/servicios"
                  class="hover:text-gold-500 transition-colors"
                  >Blanqueamiento</a
                >
              </li>
              <li>
                <a
                  href="/servicios"
                  class="hover:text-gold-500 transition-colors">Ortodoncia</a
                >
              </li>
              <li>
                <a
                  href="/servicios"
                  class="hover:text-gold-500 transition-colors">Implantes</a
                >
              </li>
            </ul>
          </div>

          <div>
            <h4 class="text-lg font-semibold mb-6">Contacto</h4>
            <ul class="space-y-3 text-gray-400">
              <li class="flex items-center gap-2">
                <svg
                  class="w-5 h-5 text-gold-500"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
                  ></path></svg
                >
                {config['footer_direccion'] || 'Av. Libertadores 1234, San Isidro'}
              </li>
              <li class="flex items-center gap-2">
                <svg
                  class="w-5 h-5 text-gold-500"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
                  ></path></svg
                >
                {config['footer_telefono'] || '+51 987 654 321'}
              </li>
              <li class="flex items-center gap-2">
                <svg
                  class="w-5 h-5 text-gold-500"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
                  ></path></svg
                >
                {config['footer_email'] || 'contacto@clinica-dental.lux'}
              </li>
            </ul>
          </div>

          <div>
            <h4 class="text-lg font-semibold mb-6">Síguenos</h4>
            <div class="flex gap-4">
              <a
                href={config['footer_facebook'] || '#'}
                target="_blank"
                class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-gold-600 transition-all duration-300 hover:scale-110 hover:shadow-lg"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                  ></path></svg
                >
              </a>
              <a
                href={config['footer_instagram'] || '#'}
                target="_blank"
                class="w-10 h-10 bg-gray-800 rounded-full flex items-center justify-center hover:bg-gold-600 transition-all duration-300 hover:scale-110 hover:shadow-lg"
              >
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
                  ><path
                    d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                  ></path></svg
                >
              </a>
            </div>
          </div>
        </div>

        <div class="border-t border-gray-800 pt-8 text-center text-gray-500">
          <p>© 2024 Clínica Dental de Lujo. Todos los derechos reservados.</p>
        </div>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;

  @layer base {
    html {
      scroll-behavior: smooth;
    }
  }

  @layer components {
    .btn-primary {
      @apply px-6 py-3 bg-gold-600 text-white font-medium rounded-lg transition-all duration-200 hover:bg-gold-700 hover:shadow-lg;
    }

    .btn-secondary {
      @apply px-6 py-3 bg-white text-gold-600 border-2 border-gold-600 font-medium rounded-lg transition-all duration-200 hover:bg-gold-50;
    }

    .section-title {
      @apply text-4xl md:text-5xl font-display font-semibold text-gray-900 mb-4;
    }

    .section-subtitle {
      @apply text-lg text-gray-600 max-w-2xl;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @keyframes pulse-glow {
    0%,
    100% {
      box-shadow: 0 0 20px rgba(212, 175, 55, 0.3);
    }
    50% {
      box-shadow: 0 0 40px rgba(212, 175, 55, 0.6);
    }
  }

  .animate-fade-in-up {
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  .animate-pulse-glow {
    animation: pulse-glow 2s ease-in-out infinite;
  }

  .hover-lift {
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
  }

  .hover-lift:hover {
    transform: translateY(-5px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
  }
</style>
